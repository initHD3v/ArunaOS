# Database
DATABASE_URL=postgres://user:password@localhost:5432/arunaos

# Redis
REDIS_URL=redis://localhost:6379

# AI Provider
# At least one provider below must be configured for AI features to work
# Provider priority: openai > openrouter > anthropic > ollama (local)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-3-haiku-20240307

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENROUTER_MODEL=openai/gpt-4o-mini

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Auth
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Storage
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000